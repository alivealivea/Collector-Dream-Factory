# Site Configuration
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Google Sheets Integration
# Service account email configured with sheet access
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account-email@project.iam.gserviceaccount.com
# Service account private key (enclose with quotes, escape newlines as \\n)
GOOGLE_PRIVATE_KEY="your-google-private-key"
# Google Sheet ID (extracted from sheet URL)
GOOGLE_SHEET_ID=your-google-sheet-id
